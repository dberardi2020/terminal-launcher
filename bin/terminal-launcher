#!/usr/bin/env python3
"""Executable entry point for Terminal Launcher.

Adds the repo's `src/` to sys.path so the `terminal_launcher` package imports without
installation, then hands off to the CLI. Symlink this onto your PATH:
    ln -s "$(pwd)/bin/terminal-launcher" ~/.local/bin/terminal-launcher
"""
import os
import sys

REPO_ROOT = os.path.dirname(os.path.dirname(os.path.realpath(__file__)))
sys.path.insert(0, os.path.join(REPO_ROOT, "src"))

from terminal_launcher.cli import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
